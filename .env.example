CRON_SECRET=replace-with-a-long-random-secret
ENFORCE_NY_8AM=true

# Required for "compare with last search".
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Option A: Resend email delivery.
RESEND_API_KEY=
EMAIL_FROM="Daily Search <you@yourdomain.com>"

# Option B: Gmail SMTP delivery.
# Requires a Google account app password, not your normal Gmail password.
GMAIL_USER=zenislander@gmail.com
GMAIL_APP_PASSWORD=
